c Every comment line starts with "c ".
c The weight format here is CACHET.

c The problem line has the form "p cnf $numVars $numClauses":
p cnf 2 3

c Every weight line has the form "w $var $weight" (either 0 <= $weight <= 1, or $weight = -1).
c By default, $weight = 0.5.

c A weight line specifying weight(x1) = 0.3 and weight(-x1) = 1 - weight(x1):
w 1 0.3

c A weight line specifying weight(x2) = weight(-x2) = 1:
w 2 -1

c Every clause line lists literals and ends with "0".

c A clause line for the positive literal x1:
1 0

c A clause line for the negative literal -x2:
-2 0

c A clause line for the disjunction x1 \/ -x2:
1 -2 0
